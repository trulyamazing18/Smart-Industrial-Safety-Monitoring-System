<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>SafeGuard AI | Enterprise Safety Monitor</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

<style>
body { background:#0f1117; color:white; padding:2rem; font-family:Inter,sans-serif;}
.dashboard-card { background:#1f2937; padding:1.5rem; border-radius:15px; margin-bottom:1.5rem;}
.video-feed { width:100%; height:500px; border-radius:15px;}
.status-box { text-align:center; font-size:1.8rem; font-weight:700; padding:2rem;}
.status-safe { background:#064e3b;}
.status-critical { background:#7f1d1d; animation:pulse 1s infinite;}
@keyframes pulse {0%{box-shadow:0 0 10px red;}50%{box-shadow:0 0 25px red;}100%{box-shadow:0 0 10px red;}}
.log-box {max-height:200px; overflow:auto; background:black; padding:1rem; border-radius:10px;}
</style>
</head>

<body>

<div class="container-fluid">

<h1 style="color:#f59e0b;">SafeGuard AI</h1>

<div class="row mt-4">

<div class="col-lg-8">
<div class="dashboard-card">
<img id="video-feed" src="{{ url_for('video_feed') }}" class="video-feed">
</div>
</div>

<div class="col-lg-4">

<div id="status-box" class="dashboard-card status-box">
<div id="status-text">Connecting...</div>
</div>

<div class="dashboard-card mt-3">
<div style="font-size:2rem;" id="worker-count">0</div>
Workers
</div>

<div class="dashboard-card">
<div id="posture-text">Stable</div>
Posture
</div>

<button id="muteBtn" class="btn btn-danger w-100 mt-3">Mute Alarm</button>

</div>
</div>

<div class="dashboard-card mt-4">
<h5>Alerts</h5>
<div id="alert-log" class="log-box"></div>
</div>

</div>

<script>

let alarmPlaying = false;
let mute = false;

// Create alarm sound
const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

function playBeep(){
    if(mute) return;

    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();

    osc.type = "square";
    osc.frequency.setValueAtTime(900, audioCtx.currentTime);

    osc.connect(gain);
    gain.connect(audioCtx.destination);

    gain.gain.setValueAtTime(0.4, audioCtx.currentTime);

    osc.start();
    osc.stop(audioCtx.currentTime + 0.2);
}

// Continuous alarm loop
setInterval(()=>{
    if(alarmPlaying){
        playBeep();
    }
},400);


// Mute button
document.getElementById("muteBtn").onclick = ()=>{
    mute = !mute;
    document.getElementById("muteBtn").innerText = mute ? "Unmute Alarm" : "Mute Alarm";
};


// Status update
async function updateStatus(){

    try{
        const res = await fetch('/status');
        const data = await res.json();

        document.getElementById("worker-count").innerText = data.worker_count;
        document.getElementById("posture-text").innerText = data.posture;
        document.getElementById("status-text").innerText = data.status;

        const box = document.getElementById("status-box");
        box.classList.remove("status-safe","status-critical");

        // 🚨 ALARM LOGIC (FINAL FIX)
        if(data.worker_count > 0 && data.status.includes("MISSING")){
            alarmPlaying = true;
            box.classList.add("status-critical");
        }
        else{
            alarmPlaying = false;
            box.classList.add("status-safe");
        }

    }catch(e){
        document.getElementById("status-text").innerText = "CONNECTION LOST";
        alarmPlaying = true;
    }
}

setInterval(updateStatus,300);
updateStatus();

</script>

</body>
</html>
